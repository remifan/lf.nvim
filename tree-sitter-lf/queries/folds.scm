; Lingua Franca folding queries

; Reactor bodies can be folded
(reactor_body) @fold

; Code blocks (target language code) can be folded
(code_block) @fold

; Mode blocks can be folded
(mode) @fold

; Key-value pairs (target config) can be folded
(key_value_pairs) @fold

; Block comments can be folded
(block_comment) @fold

; Preamble can be folded
(preamble) @fold

; Import statements (when grouped) can be folded
(import_statement) @fold
